# Server
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Database (use the Prisma connection string from Supabase)
# For production, use POSTGRES_PRISMA_URL or POSTGRES_URL_NON_POOLING from Supabase
DATABASE_URL=postgresql://user:password@host:5432/postgres

# JWT Secrets (generated with `openssl rand -base64 32`)
JWT_ACCESS_SECRET=tnn9dMI1caJu5TdCTheDgzZsecfjjCNUJkbLv4nFL6E=
JWT_REFRESH_SECRET=9XREMGH8Ll44xe74QxnikfG9u6/jg8ueGLKn/biIw/4=
JWT_RESET_SECRET=4sMVLFEluol5ma6qdcLn6G1j5SKU3BTZmahlO5jKQxA=

# JWT Expiration (optional)
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_RESET_EXPIRES_IN=15m

# Cookie names (optional)
COOKIE_NAME_ACCESS=MovieBlog_access
COOKIE_NAME_REFRESH=MovieBlog_refresh

# Supabase Storage (for image uploads)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_BUCKET=blog-images